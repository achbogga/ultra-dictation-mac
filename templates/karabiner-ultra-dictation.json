{
  "title": "Ultra Dictation",
  "rules": [
    {
      "description": "Ultra Dictation Toggle (__HOTKEY__)",
      "manipulators": [
        {
          "from": {
            "key_code": "__HOTKEY__",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            {
              "shell_command": "/bin/bash -lc '$HOME/.bin/dictation-toggle'"
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
